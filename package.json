{
  "name": "@eyalm321/github-mcp",
  "version": "1.0.2",
  "description": "MCP server for GitHub REST API — 1500+ tools covering repos, issues, actions, orgs, pulls, users, and 37 more categories",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "bin": {
    "github-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "generate": "ts-node --project tsconfig.scripts.json scripts/generate.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "github",
    "github-api",
    "rest-api",
    "claude",
    "model-context-protocol"
  ],
  "author": "Eyalm321",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eyalm321/github-mcp.git"
  },
  "homepage": "https://github.com/Eyalm321/github-mcp#readme",
  "bugs": {
    "url": "https://github.com/Eyalm321/github-mcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
